<Window x:Class="XmlWizualizator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Muflon XML" 
        Height="900" Width="1600"
        Icon="pack://application:,,,/ikona_muflon.ico">
    <Window.Resources>

        <!-- Styl dla przycisków -->
        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#005A9E"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#004578"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#CCCCCC"/>
                    <Setter Property="Foreground" Value="#666666"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Styl dla przycisku Transformuj -->
        <Style x:Key="TransformButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
            <Setter Property="Background" Value="#FF6F00"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E65100"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#C43E00"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- Styl dla przycisków nieistotnych -->
        <Style x:Key="LowImportanceButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
            <Setter Property="Background" Value="DarkGray"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="Gray"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="DimGray"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Styl dla przycisków akcji (wydruk) -->
        <Style x:Key="ActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
            <Setter Property="Background" Value="#107C10"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0E6B0E"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#0C5A0C"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Styl dla ramki wizualizacji -->
        <Style x:Key="VisualizationBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E1E1E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="15"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20" Background="White">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <!-- Lewa strona - Wizualizacja -->
        <Border Grid.Column="0" Style="{StaticResource VisualizationBorderStyle}" Margin="0,0,20,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Przełącznik trybu -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                    <RadioButton Content="Wizualizacja pliku XML" IsChecked="{Binding IsHtmlMode}"
                                Margin="0,0,20,0" FontSize="13"/>
                    <RadioButton Content="HTML" IsChecked="{Binding IsTextMode}" 
                                Margin="0,0,20,0" FontSize="13"/>
                    <RadioButton Content="Tekst XML" IsChecked="{Binding IsXmlMode}"
                                Margin="0,0,20,0" FontSize="13"/>
                    <RadioButton Content="Styl XSL" IsChecked="{Binding IsXslMode}"
                                FontSize="13"/>
                </StackPanel>

                <!-- Zawartość wizualizacji -->
                <Grid Grid.Row="1">
                    <!-- WebView2 dla trybu HTML - teraz jako pierwszy -->
                    <wv2:WebView2 x:Name="webView" 
                          DefaultBackgroundColor="White"
                          NavigationCompleted="WebView_NavigationCompleted"
                          Visibility="{Binding IsHtmlMode, Converter={StaticResource BooleanToVisibilityConverter}}"/> 

                    <!-- TextBox dla trybu tekstowego -->
                    <TextBox Text="{Binding TransformedOutput, Mode=OneWay}" 
                            IsReadOnly="True" 
                            TextWrapping="Wrap"
                            VerticalScrollBarVisibility="Auto"
                            HorizontalScrollBarVisibility="Disabled"
                            FontFamily="Consolas"
                            FontSize="12"
                            BorderThickness="0"
                            Background="White"
                            Foreground="Black"
                            Visibility="{Binding IsTextMode, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                    <!-- TextBox dla surowego XML -->
                    <TextBox Text="{Binding RawXmlContent, Mode=OneWay}" 
                            IsReadOnly="True" 
                            TextWrapping="Wrap"
                            VerticalScrollBarVisibility="Auto"
                            HorizontalScrollBarVisibility="Disabled"
                            FontFamily="Consolas"
                            FontSize="11"
                            BorderThickness="0"
                            Background="#F9F9F9"
                            Foreground="#2B579A"
                            Visibility="{Binding IsXmlMode, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                    <!-- TextBox dla surowego XSL -->
                    <TextBox Text="{Binding RawXslContent, Mode=OneWay}" 
                            IsReadOnly="True" 
                            TextWrapping="Wrap"
                            VerticalScrollBarVisibility="Auto"
                            HorizontalScrollBarVisibility="Disabled"
                            FontFamily="Consolas"
                            FontSize="11"
                            BorderThickness="0"
                            Background="#F9F9F9"
                            Foreground="DarkMagenta"
                            Visibility="{Binding IsXslMode, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </Grid>

                <!-- Pasek statusu -->
                <Border Grid.Row="2" 
                       Background="#F3F3F3" 
                       CornerRadius="4" 
                       Padding="10"
                       Margin="0,15,0,0">
                    <TextBlock Text="{Binding StatusMessage}" 
                              FontSize="12"
                              FontWeight="SemiBold"
                              Foreground="#333333"/>
                </Border>
            </Grid>
        </Border>

        <!-- Prawa strona - Panel kontrolny -->
        <Border Grid.Column="1" Style="{StaticResource VisualizationBorderStyle}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Sekcja XSL -->
                    <TextBlock Text="Szablon XSL" FontSize="16" FontWeight="Bold" 
           Foreground="#333333" Margin="0,0,0,10"/>

                    <ComboBox ItemsSource="{Binding XslFiles}"
          SelectedItem="{Binding SelectedXslPath}"
          Height="40"
          FontSize="13"
          Margin="0,0,0,25"
          Background="#0078D4"
          Foreground="White"
          BorderBrush="#005A9E"
          Padding="8,4"
          HorizontalContentAlignment="Left">

    <!-- Szablon zamkniętego ComboBox (niebieskie tło, biała etykieta) -->
    <ComboBox.Template>
        <ControlTemplate TargetType="ComboBox">
            <Grid>
                <Border x:Name="ToggleBorder"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="3"
                        Padding="{TemplateBinding Padding}">
                    <DockPanel LastChildFill="True">
                        <ContentPresenter Margin="0,0"
                                          VerticalAlignment="Bottom"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                          RecognizesAccessKey="True"
                                          Height="25"
                                          SnapsToDevicePixels="True"/>
                        <ToggleButton DockPanel.Dock="Right"
                                      IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                      Focusable="True"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      Width="30"
                                      HorizontalAlignment="Right">
                            <Path Data="M 0 0 L 4 4 L 8 0 Z" Fill="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </ToggleButton>
                    </DockPanel>
                </Border>

                <!-- Popup z listą — jasne tło, elementy listy wystylowane poniżej -->
                <Popup Name="PART_Popup"
                       Placement="Bottom"
                       IsOpen="{TemplateBinding IsDropDownOpen}"
                       AllowsTransparency="True"
                       Focusable="False"
                       PopupAnimation="Slide">
                    <Border Background="White"
                            BorderBrush="#D1D1D1"
                            BorderThickness="1"
                            CornerRadius="4"
                            SnapsToDevicePixels="True"
                            Margin="0,4,0,0">
                        <ScrollViewer Background="White" MaxHeight="300">
                            <ItemsPresenter/>
                        </ScrollViewer>
                    </Border>
                </Popup>
            </Grid>
        </ControlTemplate>
    </ComboBox.Template>

    <!-- Elementy listy: ciemny tekst na jasnym tle; selected/hover z kontrastem -->
    <ComboBox.ItemContainerStyle>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" SnapsToDevicePixels="True" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#005A9E"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E6F0FA"/>
                                <Setter Property="Foreground" Value="#111111"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#999999"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </ComboBox.ItemContainerStyle>

    <ComboBox.ItemTemplate>
        <DataTemplate>
            <TextBlock Text="{Binding Converter={StaticResource FileNameConverter}}"
                       TextTrimming="CharacterEllipsis"/>
        </DataTemplate>
    </ComboBox.ItemTemplate>
</ComboBox>

                    <!-- Separator -->
                    <Separator Margin="0,0,0,25" Background="#D1D1D1"/>


                    <!-- Sekcja XML (pojedynczy) -->
                    <TextBlock Text="Plik XML" FontSize="16" FontWeight="Bold" 
                              Foreground="#333333" Margin="0,0,0,10"/>
                    
                    <Button Content="📁 Wybierz XML" 
                           Command="{Binding SelectXmlCommand}" 
                           Style="{StaticResource ModernButtonStyle}"
                           HorizontalAlignment="Stretch"
                           Margin="0,0,0,10"/>
                    
                    <Border Background="#F3F3F3" 
                           BorderBrush="#E1E1E1" 
                           BorderThickness="1" 
                           CornerRadius="4" 
                           Padding="10"
                           Margin="0,0,0,10">
                        <TextBlock Text="{Binding SelectedXmlPath}" 
                                  TextWrapping="Wrap" 
                                  FontSize="11"
                                  Foreground="#666666"/>
                    </Border>

                    <Button Content="⚡ Transformuj" 
                           Command="{Binding TransformCommand}" 
                           Style="{StaticResource TransformButtonStyle}"
                           HorizontalAlignment="Stretch"
                           Height="45"
                           FontSize="15"
                           Margin="0,0,0,15"/>

                    <!-- Sekcja Wydruk -->
                    <TextBlock Text="Wydruk" FontSize="15" FontWeight="Bold" 
                              Foreground="#333333" Margin="0,0,0,10"/>

                    <Button Content="📄 Podgląd wydruku" 
                           Command="{Binding PrintPreviewCommand}" 
                           Style="{StaticResource ActionButtonStyle}"
                           HorizontalAlignment="Stretch"
                           Margin="0,0,0,10"/>

                    <Button Content="💾 Zapisz jako PDF" 
                           Command="{Binding PrintCommand}" 
                           Style="{StaticResource ActionButtonStyle}"
                           HorizontalAlignment="Stretch"
                           Margin="0,0,0,10"/>

                    <!-- Separator -->
                    <Separator Margin="0,15,0,25" Background="#D1D1D1"/>

                    <!-- Sekcja masowej transformacji XML -->
                    <TextBlock Text="Masowa transformacja" FontSize="16" FontWeight="Bold" 
                              Foreground="#333333" Margin="0,0,0,10"/>

                    <Button Content="📁 Wybierz wiele XML" 
                           Command="{Binding SelectMultipleXmlCommand}" 
                           Style="{StaticResource ModernButtonStyle}"
                           HorizontalAlignment="Stretch"
                           Margin="0,0,0,10"/>

                    <Button Content="🗑 Wyczyść listę" 
                           Command="{Binding ClearXmlFilesCommand}" 
                           Style="{StaticResource LowImportanceButtonStyle}"
                           HorizontalAlignment="Stretch"
                           Margin="0,0,0,5"
                           Padding="10,6"/>

                    <Border Background="#F3F3F3" 
                           BorderBrush="#E1E1E1" 
                           BorderThickness="1" 
                           CornerRadius="4" 
                           Padding="5"
                           Margin="0,0,0,10"
                           MaxHeight="150">
                        <ListBox ItemsSource="{Binding SelectedXmlPaths}" 
                                BorderThickness="0" 
                                Background="Transparent"
                                ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                  Text="{Binding Converter={StaticResource FileNameConverter}}" 
                                                  FontSize="11" 
                                                  Foreground="#666666"
                                                  VerticalAlignment="Center"
                                                  ToolTip="{Binding}"/>
                                        <Button Grid.Column="1" Content="✕" 
                                               Command="{Binding DataContext.RemoveXmlFileCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                               CommandParameter="{Binding}"
                                               FontSize="10" Cursor="Hand"
                                               Background="Transparent" BorderThickness="0"
                                               Foreground="Red" Padding="4,0"
                                               VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>

                    <Button Content="💾 Zapisz jako PDF" 
                           Command="{Binding BatchTransformCommand}"
                           Style="{StaticResource ActionButtonStyle}"
                           HorizontalAlignment="Stretch"
                           Margin="0,5,0,25"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
